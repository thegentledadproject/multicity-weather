# ══════════════════════════════════════════════════════════════════════════
# IMPORTANT: this file is loaded TWO different ways depending on how you run
# Hermes, and they parse comments differently:
#   - Local/manual runs (`python scheduler.py`) use python-dotenv, which
#     strips inline "# comment" text after a value.
#   - Production runs (via systemd, the documented deploy path) use
#     systemd's own EnvironmentFile= parser, which does NOT support inline
#     comments — everything after "=" on a line becomes part of the literal
#     value, comment text included. Confirmed: systemd/systemd issue #12527.
# For that reason every line below uses a comment on its OWN line, never
# trailing on the same line as a value. When you edit this file, follow the
# same pattern — do not add "KEY=value # comment" on one line.
# ══════════════════════════════════════════════════════════════════════════

# Polymarket CLOB credentials
# Private key: from polymarket.com/settings -> Export Private Key
POLYMARKET_PRIVATE_KEY=0x...
# Deposit wallet address: from polymarket.com/settings
POLYMARKET_FUNDER=0x...
# 0 = MetaMask/EOA, 1 = email/Magic proxy wallet, 3 = deposit wallet (ERC-1967
# proxy — see setup_deposit_wallet.py). Since Polymarket's CLOB V2 go-live,
# 0 and 1 are both rejected ("maker address not allowed, please use the
# deposit wallet flow") — 3 is the only working option as of this writing.
POLYMARKET_SIGNATURE_TYPE=3
# All three generated by running: python generate_creds.py
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# CLOB API host — override only if Polymarket changes their endpoint or
# you're pointing at a staging/alternate host. Default matches production.
CLOB_API_HOST=https://clob.polymarket.com

# Builder credentials — ONLY needed to run setup_deposit_wallet.py (one-time
# deposit-wallet provisioning), not by the live bot. Get these at
# polymarket.com/settings?tab=builder
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASS_PHRASE=
# Relayer endpoint used by setup_deposit_wallet.py — override only for
# Polymarket's staging environment.
RELAYER_URL=https://relayer-v2.polymarket.com

# Vault — each configured city (see config/cities.py) has its OWN vault,
# sized independently via VAULT_USD_<ICAO>. Unset cities fall back to their
# CityConfig.default_vault_usd.
VAULT_USD_WSSS=200.0
VAULT_USD_WMKK=100.0
# Legacy: MAX_VAULT_ALLOCATION still works as WSSS's vault size if
# VAULT_USD_WSSS isn't set (pre-multi-city .env compatibility). Prefer
# VAULT_USD_WSSS in new configs.
# MAX_VAULT_ALLOCATION=200.0

# Edge threshold (5% = 0.05)
EDGE_THRESHOLD=0.05

# Max edge magnitude (50% = 0.50) — signals with |edge| above this are gated
# as SKIP_EXTREME_EDGE rather than traded. A tight-spread, liquid market
# pricing near-certainty of the OPPOSITE of what the model says is more
# often evidence the model's stated uncertainty (sigma) is too tight than a
# genuinely huge mispriced opportunity — see core/edge.py's module docstring.
MAX_EDGE_MAGNITUDE=0.50

# Kelly fraction: 0.50 = half Kelly (raised from 0.25 to clear $10 floor at $200 vault)
KELLY_FRACTION=0.50

# Tiered EV hurdle for sub-$25 positions (8% = 0.08, lowered from 0.15)
SMALL_EV_HURDLE=0.08

# Max position size as % of vault per trade (15% = 0.15, raised from 5%).
# At 5%, the cap only cleared the $10 floor once vault >= $200 -- WSSS's
# $200 vault sat exactly on that boundary (every trade forced to identical
# $10 size regardless of edge), and WMKK's $100 vault sat below it (cap=$5
# < floor=$10, so normal Kelly sizing could never execute at all). 15%
# gives real range for both: WSSS $10-$30, WMKK $10-$15.
MAX_POSITION_PCT=0.15

# Re-entry cooldown (minutes) — after a bracket exits via STOP_LOSS or
# TRAILING_STOP (adverse-move exits, unlike the scheduled TIME_EXIT), block
# reopening that SAME bracket for this long. Added after a live trade log
# showed the same bracket stop-lossing and reopening repeatedly within
# single 15-min cycles, compounding losses.
REENTRY_COOLDOWN_MINUTES=60

# Trailing stop: % drawdown from peak before exit (20% = 0.20)
TRAIL_PCT=0.20

# VALIDATION MODE — forces $1 trades on any actionable signal, bypassing
# Kelly sizing and EV hurdles. Full lifecycle (entry/trail/stop/settlement)
# still runs for real money. Use to validate mechanics before deploying full
# capital. Set to false once validation is complete — DO NOT leave true in
# production. This is the global fallback for any city without its own
# VALIDATION_MODE_<ICAO> override below.
VALIDATION_MODE=false
VALIDATION_POSITION_USD=1.00

# Per-city validation override — VALIDATION_MODE_<ICAO> takes precedence
# over the global VALIDATION_MODE above for that city only, so one city can
# run $1 validation trades while another keeps running normal Kelly sizing
# (or stays in paper mode — see config.cities.CityConfig.paper_trading,
# which is a code-level flag, not an env var, and takes priority over both:
# a paper_trading=True city never places a real order regardless of what's
# set here). Uncomment to use:
# VALIDATION_MODE_WSSS=false
# VALIDATION_MODE_WMKK=false

# DB path
DB_PATH=hermes.db
